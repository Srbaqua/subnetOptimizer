# -----------------------
/client/node_modules/
/client/build/
/client/dist/
/client/.next/
/client/.parcel-cache/
/client/.cache/
/client/.env
/client/.env.local
/client/logs/

# Typical frontend tool files
/client/.eslintcache
/client/.turbo/
/client/.vite/

# -----------------------
# Server (backend)
# -----------------------
/server/node_modules/
/server/dist/
/server/build/
/server/.cache/
/server/logs/
/server/.env
/server/.env.local
/server/*.pem
/server/*.key
/server/*.crt

# If server is Python
/server/venv/
/server/env/
/server/__pycache__/
/server/*.py[cod]

# If server is Go / compiled languages
/server/bin/
/server/*.exe
/server/*.dll
/server/*.so
/server/*.dylib

